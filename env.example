# =============================================================
# ElinosaAI — Environment Variables
# Nosana x ElizaOS Builders Challenge
# =============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# LLM Configuration — Qwen3.5 via Nosana Inference Endpoint
# -------------------------------------------------------------
# Nosana provides a hosted Qwen endpoint. No GPU required locally.
OPENAI_API_KEY=nosana
OPENAI_API_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1
MODEL_NAME=Qwen/Qwen3.5-4B

# -------------------------------------------------------------
# Embedding Configuration — via Nosana Inference Endpoint
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# -------------------------------------------------------------
# Option B: Local development with Ollama (optional)
# -------------------------------------------------------------
# Install Ollama: https://ollama.com/download
# Then run: ollama pull qwen3:8b && ollama serve
#
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3:8b

# -------------------------------------------------------------
# Agent Server
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# Database (SQLite — created automatically)
# -------------------------------------------------------------
# SQLITE_DATA_DIR=./data

# -------------------------------------------------------------
# Helius API — Wallet Activity Lookup (free tier)
# -------------------------------------------------------------
# Sign up free at https://helius.xyz — 100K requests/month
# Required for CHECK_WALLET action. ANALYZE_TOKEN works without it.
HELIUS_API_KEY=your_helius_api_key_here

# -------------------------------------------------------------
# Telegram Bot (optional — for Telegram interface)
# -------------------------------------------------------------
# 1. Message @BotFather on Telegram
# 2. Type /newbot and follow the prompts
# 3. Paste your token below
# 4. Run: bun run telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# In production, set this to your live Nosana deployment URL
# AGENT_BASE_URL=https://your-nosana-deployment-url

# -------------------------------------------------------------
# Twitter/X (optional — for X bot)
# -------------------------------------------------------------
# TWITTER_USERNAME=
# TWITTER_PASSWORD=
# TWITTER_EMAIL=

# -------------------------------------------------------------
# Discord (optional)
# -------------------------------------------------------------
# DISCORD_API_TOKEN=
